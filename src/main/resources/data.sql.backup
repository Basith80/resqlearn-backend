DROP TABLE IF EXISTS `virtual_drills`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `virtual_drills` (
  `id` bigint NOT NULL AUTO_INCREMENT,
  `correct_option` varchar(255) NOT NULL,
  `optiona` varchar(255) NOT NULL,
  `optionb` varchar(255) NOT NULL,
  `optionc` varchar(255) NOT NULL,
  `optiond` varchar(255) NOT NULL,
  `scenario` varchar(255) NOT NULL,
  `time_limit_seconds` int NOT NULL,
  `disaster_id` bigint NOT NULL,
  PRIMARY KEY (`id`),
  KEY `FKnbeim9978ef3lr7yrsxcia9f9` (`disaster_id`),
  CONSTRAINT `FKnbeim9978ef3lr7yrsxcia9f9` FOREIGN KEY (`disaster_id`) REFERENCES `disaster` (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=118 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

